{
  "name": "suwol-view",
  "productName": "SuwolView",
  "version": "0.2.0",
  "description": "Free open-source cross-platform image, comic, webtoon, and metadata viewer.",
  "license": "Apache-2.0",
  "author": "SuwolView contributors",
  "private": true,
  "engines": {
    "node": ">=22 <25"
  },
  "type": "module",
  "main": "dist-electron/main.cjs",
  "files": [
    "dist",
    "dist-electron",
    "LICENSE",
    "NOTICE",
    "THIRD_PARTY_LICENSES.md"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "assets:icons": "npm run icons:generate",
    "icons:generate": "node scripts/generate-icons.mjs",
    "icons:check": "node scripts/check-icons.mjs",
    "i18n:check": "node scripts/check-i18n.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "build:renderer": "vite build",
    "build:main": "vite build --config vite.main.config.ts",
    "build": "npm run build:renderer && npm run build:main",
    "dist": "npm run build && electron-builder",
    "dist:win:zip": "npm run build && electron-builder --win zip --publish never",
    "dist:linux:zip": "npm run build && electron-builder --linux zip --publish never",
    "dist:linux:dir": "npm run build && electron-builder --linux dir --publish never",
    "release:collect": "node scripts/collect-release-artifact.mjs",
    "license:check": "node scripts/check-licenses.mjs",
    "package:smoke": "node scripts/package-smoke-test.mjs",
    "verify": "npm run icons:check && npm run i18n:check && npm run typecheck && npm run lint && npm run test && npm run build && npm run license:check && npm run package:smoke"
  },
  "dependencies": {
    "exifr": "7.1.3",
    "i18next": "26.3.4",
    "lucide-react": "1.23.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-i18next": "17.0.8",
    "sharp": "0.35.3",
    "yauzl": "3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/yauzl": "3.4.0",
    "@vitejs/plugin-react": "6.0.3",
    "electron": "43.0.0",
    "electron-builder": "26.15.3",
    "eslint": "10.6.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vite": "8.1.3",
    "vitest": "4.1.9"
  }
}
